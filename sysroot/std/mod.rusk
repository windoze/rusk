// `std` is a source wrapper around host modules.
//
// It is only loaded by the compiler when the `_std_host` host module is declared.
// The standard sysroot expects both `_std_host` and `_std_host_async` to be declared by the host.

pub mod async;
pub mod time;
pub mod http;
pub mod json;

pub use loaf::_std_host::print;
pub use loaf::_std_host::println;
