// expect: ok int 42

interface E { fn boom() -> int; }

mod test {
    pub extern fn store_cont(k: cont(int) -> int) -> unit;
    pub extern fn take_cont() -> cont(int) -> int;
}

fn main() -> int {
    match @E.boom() {
        @E.boom() -> k => { test::store_cont(k); 0 }
        x => x
    };
    let k = test::take_cont();
    k(42)
}
